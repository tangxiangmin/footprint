{
  "name": "@footprintjs/sdk-vue",
  "version": "1.0.6",
  "description": "footprint 埋点 SDK 通用指令层：v-log 点击/曝光指令",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "keywords": ["tracking", "analytics", "sdk", "vue", "directive"],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@footprintjs/sdk-core": "workspace:^1.0.0",
    "intersection-observer": "^0.12.0"
  }
}
