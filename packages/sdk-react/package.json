{
  "name": "@footprintjs/sdk-react",
  "version": "1.0.0",
  "description": "footprint 埋点 SDK React 适配：useTrackTask Hook",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "keywords": ["tracking", "analytics", "sdk", "react"],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@footprintjs/sdk-core": "workspace:^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0"
  }
}
