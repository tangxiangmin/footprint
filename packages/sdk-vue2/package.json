{
  "name": "@footprintjs/sdk-vue2",
  "version": "1.1.0",
  "description": "footprint 埋点 SDK Vue2 适配：路由 mixin + v-log 指令",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "keywords": [
    "tracking",
    "analytics",
    "sdk",
    "vue2"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@footprintjs/sdk-core": "workspace:^1.1.0",
    "@footprintjs/sdk-vue": "workspace:^1.1.0"
  },
  "devDependencies": {
    "vue": "^2.6.14",
    "vue-router": "^3.2.31"
  },
  "peerDependencies": {
    "vue": "^2.6.14",
    "vue-router": "^3.2.31"
  }
}
