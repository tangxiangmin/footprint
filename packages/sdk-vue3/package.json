{
  "name": "@footprintjs/sdk-vue3",
  "version": "1.0.9",
  "description": "footprint 埋点 SDK Vue3 适配：useTrackTask + v-log 指令",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "keywords": ["tracking", "analytics", "sdk", "vue3"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@footprintjs/sdk-core": "workspace:^1.0.0",
    "@footprintjs/sdk-vue": "workspace:^1.0.0"
  },
  "peerDependencies": {
    "vue": "^3.2.25",
    "vue-router": "^4.0.0"
  }
}
