{
  "name": "footprint",
  "version": "1.0.0",
  "description": "footprint === 轻量级前端埋点 SDK（core / vue / vue2 / vue3 / react）",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/sdk-*\" run build",
    "dev": "pnpm -r --parallel --filter \"./packages/sdk-*\" run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "check-registry": "npm whoami --registry https://registry.npmjs.org/",
    "release": "pnpm check-registry && pnpm build && changeset publish"
  },
  "keywords": ["tracking", "analytics", "sdk", "vue", "react"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "@parcel/watcher", "esbuild", "vue-demi"]
  }
}
